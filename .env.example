# API Keys for Bifrost
OPENAI_KEY=your-openai-api-key-here
OPENROUTER_KEY=your-openrouter-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
KIMI_API_KEY=your-kimi-api-key-here

# Proxy configuration (macOS: 7897, VPS: 7890)
OPENROUTER_PROXY_URL=http://host.docker.internal:7897
OPENAI_PROXY_URL=http://host.docker.internal:7897

# OpenAI-compatible base URLs
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Embedding Service Configuration (optional overrides)
# These are defaults in config.json, but can be overridden here
# EMBEDDING_SERVICE_URL=http://embedding-service:8001
# EMBEDDING_SERVICE_TIMEOUT_MS=500
# EMBEDDING_CONFIDENCE_THRESHOLD=0.5

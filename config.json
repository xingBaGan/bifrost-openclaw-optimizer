{
  "$schema": "https://www.getbifrost.ai/schema",
  "vector_store": {
    "enabled": true,
    "type": "redis",
    "config": {
      "addr": "redis:6379"
    }
  },
  "plugins": [
    {
      "enabled": false,
      "name": "smart-classifier",
      "config": {}
    },
    {
      "enabled": true,
      "name": "classifier",
      "config": {
        "embedding_service": {
          "enabled": true,
          "url": "http://embedding-service:8001",
          "timeout_ms": 500,
          "confidence_threshold": 0.5,
          "fallback_to_rules": true
        }
      }
    },
    {
      "enabled": false,
      "name": "semantic_cache",
      "config": {
        "dimension": 1,
        "ttl": "1h",
        "cleanup_on_shutdown": false,
        "cache_by_model": true,
        "cache_by_provider": true
      }
    }
  ],
  "providers": {
    "openai": {
      "keys": [
        {
          "name": "openai-key-1",
          "value": "env.OPENAI_KEY",
          "models": [
            "gpt-4o",
            "o1",
            "o3",
            "chatgpt-4o-latest"
          ],
          "weight": 1.0
        }
      ],
      "proxy_config": {
        "type": "http",
        "url": "http://host.docker.internal:7897"
      },
      "network_config": {
        "default_request_timeout_in_seconds": 60,
        "max_retries": 1,
        "retry_backoff_initial_ms": 100,
        "retry_backoff_max_ms": 2000
      },
      "concurrency_and_buffer_size": {
        "concurrency": 3,
        "buffer_size": 10
      }
    },
    "openrouter": {
      "keys": [
        {
          "name": "openrouter-key-1",
          "value": "env.OPENROUTER_KEY",
          "models": [
            "x-ai/grok-4.20",
            "anthropic/claude-3.5-sonnet",
            "nousresearch/hermes-4-405b"
          ],
          "weight": 1.0
        }
      ],
      "proxy_config": {
        "type": "http",
        "url": "http://host.docker.internal:7897"
      },
      "network_config": {
        "default_request_timeout_in_seconds": 60,
        "max_retries": 1,
        "retry_backoff_initial_ms": 100,
        "retry_backoff_max_ms": 2000
      },
      "concurrency_and_buffer_size": {
        "concurrency": 3,
        "buffer_size": 10
      }
    },
    "deepseek": {
      "keys": [
        {
          "name": "deepseek-key-1",
          "value": "env.DEEPSEEK_API_KEY",
          "models": [
            "deepseek-chat",
            "deepseek-reasoner"
          ],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.deepseek.com/v1",
        "default_request_timeout_in_seconds": 60,
        "max_retries": 1,
        "retry_backoff_initial_ms": 100,
        "retry_backoff_max_ms": 2000
      },
      "concurrency_and_buffer_size": {
        "concurrency": 3,
        "buffer_size": 10
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        },
        "request_path_overrides": {
          "chat_completion": "/chat/completions",
          "chat_completion_stream": "/chat/completions"
        }
      }
    },
    "kimi": {
      "keys": [
        {
          "name": "kimi-key-1",
          "value": "env.KIMI_API_KEY",
          "models": [
            "kimi-k2.5",
            "kimi-k2-thinking"
          ],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.moonshot.cn/v1",
        "default_request_timeout_in_seconds": 60,
        "max_retries": 1,
        "retry_backoff_initial_ms": 100,
        "retry_backoff_max_ms": 2000
      },
      "concurrency_and_buffer_size": {
        "concurrency": 3,
        "buffer_size": 10
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        },
        "request_path_overrides": {
          "chat_completion": "/chat/completions",
          "chat_completion_stream": "/chat/completions"
        }
      }
    }
  },
  "governance": {
    "routing_rules": [
      {
        "id": "rr-text-large-context",
        "name": "text-large-context",
        "description": "Large context texts (>32k tokens) -> Kimi (supports 200k+)",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && headers[\"x-context-size\"] == \"large\"",
        "targets": [
          {
            "provider": "kimi",
            "model": "kimi-k2.5",
            "weight": 1
          }
        ],
        "scope": "global",
        "priority": 1
      },
      {
        "id": "rr-text-structured",
        "name": "text-structured-output",
        "description": "Requires Tools/JSON -> Kimi (primary) or OpenAI (fallback)",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && (headers[\"x-has-tools\"] == \"true\" || headers[\"x-has-json-output\"] == \"true\")",
        "targets": [
          {
            "provider": "kimi",
            "model": "kimi-k2.5",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openai/gpt-4o"
        ],
        "scope": "global",
        "priority": 2
      },
      {
        "id": "rr-vision-quality-think",
        "name": "vision-quality-think",
        "description": "Vision + quality + think -> Kimi (primary), OpenAI (fallback)",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"vision\" && headers[\"x-tier\"] == \"quality\" && headers[\"x-reasoning\"] == \"think\"",
        "targets": [
          {
            "provider": "kimi",
            "model": "kimi-k2-thinking",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openai/o3",
          "openai/o1"
        ],
        "scope": "global",
        "priority": 10
      },
      {
        "id": "rr-vision-quality-fast",
        "name": "vision-quality-fast",
        "description": "Vision + quality + fast -> Kimi (primary), OpenAI (fallback)",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"vision\" && headers[\"x-tier\"] == \"quality\" && headers[\"x-reasoning\"] == \"fast\"",
        "targets": [
          {
            "provider": "kimi",
            "model": "kimi-k2.5",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openai/o3",
          "openai/o1"
        ],
        "scope": "global",
        "priority": 11
      },
      {
        "id": "rr-vision-research",
        "name": "vision-research",
        "description": "Vision + research -> OpenRouter Grok (primary), Claude 3.5 Sonnet (fallback)",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"vision\" && headers[\"x-tier\"] == \"research\"",
        "targets": [
          {
            "provider": "openrouter",
            "model": "x-ai/grok-4.20",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openrouter/anthropic/claude-3.5-sonnet"
        ],
        "scope": "global",
        "priority": 12
      },
      {
        "id": "rr-vision-economy",
        "name": "vision-economy",
        "description": "Vision + economy -> Kimi (economy vision safe)",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"vision\" && headers[\"x-tier\"] == \"economy\"",
        "targets": [
          {
            "provider": "kimi",
            "model": "kimi-k2.5",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openai/o3",
          "openai/o1"
        ],
        "scope": "global",
        "priority": 13
      },
      {
        "id": "rr-text-economy-fast",
        "name": "text-economy-fast",
        "description": "Text + economy + fast -> DeepSeek chat",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && headers[\"x-tier\"] == \"economy\" && headers[\"x-reasoning\"] == \"fast\"",
        "targets": [
          {
            "provider": "deepseek",
            "model": "deepseek-chat",
            "weight": 1
          }
        ],
        "scope": "global",
        "priority": 20
      },
      {
        "id": "rr-text-economy-think",
        "name": "text-economy-think",
        "description": "Text + economy + think -> DeepSeek reasoner",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && headers[\"x-tier\"] == \"economy\" && headers[\"x-reasoning\"] == \"think\"",
        "targets": [
          {
            "provider": "deepseek",
            "model": "deepseek-reasoner",
            "weight": 1
          }
        ],
        "scope": "global",
        "priority": 21
      },
      {
        "id": "rr-text-quality-fast",
        "name": "text-quality-fast",
        "description": "Text + quality + fast -> Kimi",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && headers[\"x-tier\"] == \"quality\" && headers[\"x-reasoning\"] == \"fast\"",
        "targets": [
          {
            "provider": "kimi",
            "model": "kimi-k2.5",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openai/o3",
          "openai/o1"
        ],
        "scope": "global",
        "priority": 22
      },
      {
        "id": "rr-text-quality-think",
        "name": "text-quality-think",
        "description": "Text + quality + think -> Kimi (primary), OpenAI (fallback)",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && headers[\"x-tier\"] == \"quality\" && headers[\"x-reasoning\"] == \"think\"",
        "targets": [
          {
            "provider": "kimi",
            "model": "kimi-k2-thinking",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openai/o3",
          "openai/o1"
        ],
        "scope": "global",
        "priority": 23
      },
      {
        "id": "rr-text-research-think",
        "name": "text-research-think",
        "description": "Text + research + think -> OpenRouter Grok (primary), Claude 3.5 Sonnet, Hermes 4 405B",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && headers[\"x-tier\"] == \"research\" && headers[\"x-reasoning\"] == \"think\"",
        "targets": [
          {
            "provider": "openrouter",
            "model": "x-ai/grok-4.20",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openrouter/anthropic/claude-3.5-sonnet",
          "openrouter/nousresearch/hermes-4-405b"
        ],
        "scope": "global",
        "priority": 30
      },
      {
        "id": "rr-text-research-fast",
        "name": "text-research-fast",
        "description": "Text + research + fast -> OpenRouter Grok (primary), Claude 3.5 Sonnet, Hermes 4 405B",
        "enabled": true,
        "cel_expression": "headers[\"x-modality\"] == \"text\" && headers[\"x-tier\"] == \"research\" && headers[\"x-reasoning\"] == \"fast\"",
        "targets": [
          {
            "provider": "openrouter",
            "model": "x-ai/grok-4.20",
            "weight": 1
          }
        ],
        "fallbacks": [
          "openrouter/anthropic/claude-3.5-sonnet",
          "openrouter/nousresearch/hermes-4-405b"
        ],
        "scope": "global",
        "priority": 31
      }
    ]
  }
}